{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loreweaver.local/schemas/runtime_feature_pack.schema.json",
  "title": "LoreWeaver Runtime Feature Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "abilityCatalog",
    "passiveSkillCatalog",
    "characterDesignCatalog",
    "enemyDesignCatalog",
    "skillEffectCatalog",
    "audioCueCatalog",
    "requiredWorkbenchArtifacts",
    "acceptanceGates"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "abilityCatalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ability"
      }
    },
    "passiveSkillCatalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/passiveSkill"
      }
    },
    "characterDesignCatalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/characterDesign"
      }
    },
    "enemyDesignCatalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/enemyDesign"
      }
    },
    "skillEffectCatalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/skillEffect"
      }
    },
    "audioCueCatalog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/audioCue"
      }
    },
    "requiredWorkbenchArtifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "acceptanceGates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_\\-]*$"
    },
    "palette": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^#?[0-9a-fA-F]{3,8}$"
      }
    },
    "ability": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "description",
        "unlockSource",
        "unlockCondition",
        "runtimeSkillIds",
        "affectedNodeIds",
        "designRole"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string"
        },
        "lineage": {
          "type": "string"
        },
        "unlockSource": {
          "enum": [
            "initial",
            "mainline",
            "node_reward",
            "hybrid",
            "finale"
          ]
        },
        "unlockCondition": {
          "type": "string",
          "minLength": 1
        },
        "gameplayTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "runtimeSkillIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "affectedNodeIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "uniqueItems": true
        },
        "designRole": {
          "type": "string",
          "minLength": 1
        },
        "characterHooks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "vfxConcept": {
          "type": "object",
          "required": [
            "palette",
            "shapeLanguage"
          ],
          "properties": {
            "palette": {
              "$ref": "#/$defs/palette"
            },
            "shapeLanguage": {
              "type": "string",
              "minLength": 1
            },
            "runtimeNotes": {
              "type": "string"
            }
          }
        },
        "sfxCues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "passiveSkill": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "treeTier",
        "cost",
        "effects",
        "description",
        "uiCopy"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "treeTier": {
          "type": "string",
          "minLength": 1
        },
        "cost": {
          "type": "number",
          "minimum": 0
        },
        "requires": {
          "type": [
            "string",
            "null"
          ]
        },
        "effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "target",
              "op",
              "value"
            ]
          }
        },
        "affectedRuntimeSkillIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "uiCopy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "characterDesign": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "role",
        "appearsNodeIds",
        "combatIdentity",
        "visualDesign",
        "animationCues",
        "skillConnections"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "appearsNodeIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "visualDesign": {
          "type": "object",
          "required": [
            "silhouette",
            "palette"
          ],
          "properties": {
            "silhouette": {
              "type": "string",
              "minLength": 1
            },
            "palette": {
              "$ref": "#/$defs/palette"
            },
            "stageVariants": {
              "type": "array"
            }
          }
        },
        "animationCues": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "skillConnections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "enemyDesign": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "runtimeEnemyId",
        "silhouette",
        "palette",
        "combatRead"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "runtimeEnemyId": {
          "$ref": "#/$defs/id"
        },
        "silhouette": {
          "type": "string",
          "minLength": 1
        },
        "palette": {
          "$ref": "#/$defs/palette"
        },
        "combatRead": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "skillEffect": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "runtimeSkillId",
        "shape",
        "palette",
        "implementation"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "runtimeSkillId": {
          "$ref": "#/$defs/id"
        },
        "shape": {
          "type": "string",
          "minLength": 1
        },
        "palette": {
          "$ref": "#/$defs/palette"
        },
        "screenShake": {
          "type": "object",
          "properties": {
            "durationMs": {
              "type": "number",
              "minimum": 0
            },
            "intensity": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "implementation": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "audioCue": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "runtimeSkillId",
        "synth",
        "mixRole",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "runtimeSkillId": {
          "$ref": "#/$defs/id"
        },
        "synth": {
          "type": "object",
          "required": [
            "frequencies",
            "wave",
            "durationMs",
            "volume"
          ],
          "properties": {
            "frequencies": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "number",
                "minimum": 1
              }
            },
            "wave": {
              "type": "string",
              "minLength": 1
            },
            "durationMs": {
              "type": "number",
              "minimum": 1
            },
            "volume": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "mixRole": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
