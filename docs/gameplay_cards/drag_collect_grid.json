{
  "schemaVersion": "1.0",
  "id": "drag_collect_grid",
  "title": "Drag Collect Grid",
  "category": "collection_puzzle",
  "status": "candidate",
  "runtime": {
    "engineTargets": ["html_canvas", "phaser"],
    "adapter": "DragCollectGridAdapter",
    "container": "node_iframe_microgame"
  },
  "inputs": ["pointer_drag", "touch_drag"],
  "objectives": ["collect_target_amount"],
  "failure": ["timer_expired", "mistakes_exhausted", "retreated"],
  "knobs": {
    "gridCols": {
      "type": "integer",
      "default": 8,
      "min": 3,
      "max": 16,
      "patchLevel": "L1",
      "description": "Grid columns."
    },
    "gridRows": {
      "type": "integer",
      "default": 10,
      "min": 3,
      "max": 20,
      "patchLevel": "L1",
      "description": "Grid rows."
    },
    "timeLimitSec": {
      "type": "number",
      "default": 40,
      "min": 5,
      "max": 300,
      "patchLevel": "L1",
      "description": "Time limit."
    },
    "needAmount": {
      "type": "integer",
      "default": 16,
      "min": 1,
      "max": 999,
      "patchLevel": "L1",
      "description": "Target items to collect."
    },
    "mistakesMax": {
      "type": "integer",
      "default": 3,
      "min": 0,
      "max": 20,
      "patchLevel": "L1",
      "description": "Allowed wrong collections."
    },
    "allowDiagonal": {
      "type": "boolean",
      "default": false,
      "patchLevel": "L1",
      "description": "Whether diagonal path links are valid."
    }
  },
  "patchPolicy": {
    "defaultAllowedLevels": ["L0", "L1", "L2"],
    "requiresReview": ["L3", "L4"]
  },
  "requiredCoreSystems": ["Grid", "DragPath", "MatchValidator", "Timer", "NodeResult"],
  "resultContract": {
    "successReason": "objective_met",
    "failureReason": "timer_expired"
  },
  "testFixture": {
    "type": "e2e",
    "path": null,
    "assertions": [
      "drag path selects adjacent cells",
      "valid target path increases collection",
      "wrong type decrements mistake or time",
      "target amount sends NodeResult"
    ]
  },
  "sourceProvenance": [
    "minigame/Path_to_Immortality/node2.html"
  ],
  "fit": {
    "goodFor": ["gathering", "alchemy prep", "gem matching", "resource collection"],
    "poorFor": ["high-action combat", "narrative-only nodes"]
  },
  "knownRisks": [
    "mobile drag can conflict with page scrolling unless touch-action is controlled",
    "board must guarantee enough reachable target items"
  ]
}
