  "handoffTypes": [
    "request",
    "ack",
    "reject",
    "escalate"
  ],
  "departmentStatuses": [
    "idle",
    "drafting",
    "ready_for_review",
    "confirmed",
    "blocked",
    "stale"
  ],
  "unitTypes": [
    "campaign",
    "node",
    "card",
    "export"
  ],
  "autoPrepPolicy": {
    "defaultStopAt": "ready_for_review",
    "requireHumanConfirm": true,
    "minQaScoreToReady": 70
  }
}
