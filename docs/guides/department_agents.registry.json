      "uiTabs": [
        "prepNotes",
        "qaReport",
        "handoffs"
      ],
      "chatAgentId": "code_foundry"
    },
    {
      "id": "qa",
      "title": "质检组",
      "titleEn": "QA / Auditor",
      "avatar": "👁️",
      "group": "verification",
      "legacyAgentIds": [
        "auditor"
      ],
      "pipelineSteps": [
        "3.3"
