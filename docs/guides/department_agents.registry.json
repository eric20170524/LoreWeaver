      "defaultPatchLevels": [
        "L0",
        "L1",
        "L2"
      ],
      "dependsOn": [
        "world",
        "gameplay",
        "ability"
      ],
      "systemPromptRole": "Plan BGM/SFX/voice manifests and channel coverage matrix.",
