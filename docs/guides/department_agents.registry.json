      "id": "audio",
      "title": "音频组",
      "titleEn": "Audio",
      "avatar": "🔊",
      "group": "assets",
      "legacyAgentIds": [],
      "pipelineSteps": [
        "2.3",
        "3.2"
      ],
      "owns": [
        "asset-pipeline.audioAssets",
        "audio cues",
        "credits"
