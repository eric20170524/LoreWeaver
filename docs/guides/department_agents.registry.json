      "title": "制作筹备",
      "titleEn": "Production Prep"
    },
    {
      "id": "asset_confirm",
      "title": "资产确认",
      "titleEn": "Asset Confirm"
    },
    {
      "id": "runtime_stage",
      "title": "运行就绪",
      "titleEn": "Runtime Ready"
    }
  ],
  "departments": [
