      "uiTabs": [
        "prepNotes",
        "qaReport",
        "handoffs"
      ],
      "chatAgentId": "auditor"
    },
    {
      "id": "compliance",
      "title": "合规组",
      "titleEn": "Compliance",
      "avatar": "⚖️",
      "group": "verification",
      "legacyAgentIds": [
        "auditor"
      ],
      "pipelineSteps": [
        "3.3",
        "export"
