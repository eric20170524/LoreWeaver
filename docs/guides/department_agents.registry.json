        "prepNotes",
        "qaReport",
        "handoffs"
      ],
      "chatAgentId": "code_foundry"
    },
    {
      "id": "code",
      "title": "代码组",
      "titleEn": "Code Foundry",
      "avatar": "⚙️",
      "group": "engineering",
      "legacyAgentIds": [
        "code_foundry"
      ],
      "pipelineSteps": [
        "3.1",
        "3.2"
      ],
      "owns": [
        "adapter wiring",
