{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loreweaver.gameplay-card.v2",
  "title": "Gameplay Card V2",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "status",
    "runtime",
    "inputs",
    "objectives",
    "failure",
    "maturityImpact",
    "performanceBudget",
    "testScenarios"
  ],
  "properties": {
    "schemaVersion": { "const": "2.0" },
    "id": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9_]+$" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["design_only", "candidate", "validated", "deprecated"] },
    "runtime": {
      "type": "object",
      "required": ["template", "engineTargets", "adapter"],
      "properties": {
        "template": { "type": "string" },
        "engineTargets": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "adapter": { "type": "string" }
      }
    },
    "inputs": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "objectives": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "failure": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "requiredAssets": {
      "type": "object",
      "properties": {
        "playerClips": { "type": "array", "items": { "type": "string" } },
        "enemyKinds": { "type": "array", "items": { "type": "string" } },
        "environments": { "type": "array", "items": { "type": "string" } },
        "audioCues": { "type": "array", "items": { "type": "string" } }
      }
    },
    "balanceModel": {
      "type": "object",
      "properties": {
        "freshBossTtkSeconds": { "type": "number" },
        "fullBossMinTtkSeconds": { "type": "number" },
        "maxMandatoryRepeats": { "type": "integer" }
      }
    },
    "scoreModel": {
      "type": "object",
      "properties": {
        "nodeMinimum": { "type": "number" },
        "keyNodeMinimum": { "type": "number" },
        "campaignAverage": { "type": "number" }
      }
    },
    "testScenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "tags"],
        "properties": {
          "id": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "nodeId": { "type": "integer" }
        }
      }
    },
    "performanceBudget": {
      "type": "object",
      "required": ["normalP95Fps", "bossP95Fps"],
      "properties": {
        "normalP95Fps": { "type": "number" },
        "bossP95Fps": { "type": "number" },
        "maxActiveEnemies": { "type": "integer" }
      }
    },
    "compatibleModifiers": { "type": "array", "items": { "type": "string" } },
    "maturityImpact": {
      "type": "object",
      "required": ["dimensions"],
      "properties": {
        "dimensions": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "notes": { "type": "string" }
      }
    },
    "exportPolicy": {
      "type": "object",
      "properties": {
        "productionReady": { "type": "boolean" },
        "blockReason": { "type": ["string", "null"] }
      }
    }
  },
  "additionalProperties": true
}
