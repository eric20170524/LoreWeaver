{
  "schemaVersion": "2.0",
  "id": "rhythm_timing",
  "title": "Rhythm Timing",
  "category": "timing",
  "status": "gate_verified",
  "runtime": {
    "engineTargets": [
      "html_canvas",
      "phaser"
    ],
    "adapter": "TapReactionAdapter",
    "container": "node_iframe_microgame",
    "template": "rhythm_timing"
  },
  "inputs": [
    "button",
    "pointer"
  ],
  "objectives": [
    "reach_progress",
    "reach_combo"
  ],
  "failure": [
    "retreated",
    "optional_timer_expired"
  ],
  "knobs": {
    "beatIntervalMs": {
      "type": "integer",
      "default": 1500,
      "min": 300,
      "max": 5000,
      "patchLevel": "L1",
      "description": "Timing cycle length."
    },
    "perfectWindowMs": {
      "type": "integer",
      "default": 80,
      "min": 10,
      "max": 500,
      "patchLevel": "L1",
      "description": "Perfect hit timing window."
    },
    "goodWindowMs": {
      "type": "integer",
      "default": 160,
      "min": 10,
      "max": 800,
      "patchLevel": "L1",
      "description": "Good hit timing window."
    },
    "targetProgress": {
      "type": "integer",
      "default": 100,
      "min": 10,
      "max": 1000,
      "patchLevel": "L1",
      "description": "Progress required to complete the node."
    },
    "requiredBestCombo": {
      "type": "integer",
      "default": 18,
      "min": 0,
      "max": 200,
      "patchLevel": "L1",
      "description": "Optional best combo requirement."
    },
    "spawnIntervalMs": {
      "type": "integer",
      "default": 1200,
      "min": 300,
      "max": 5000,
      "patchLevel": "L1",
      "description": "Alias of beatIntervalMs for adapter spawn loop."
    },
    "orbLifetimeMs": {
      "type": "integer",
      "default": 2500,
      "min": 400,
      "max": 8000,
      "patchLevel": "L1",
      "description": "How long a reaction orb remains clickable."
    },
    "skipBoss": {
      "type": "boolean",
      "default": false,
      "patchLevel": "L1",
      "description": "When true, pure timing loop without boss phase (demo/gate)."
    },
    "durationSec": {
      "type": "integer",
      "default": 30,
      "min": 10,
      "max": 600,
      "patchLevel": "L1",
      "description": "Run duration seconds."
    },
    "goalValue": {
      "type": "integer",
      "default": 15,
      "min": 1,
      "max": 1000,
      "patchLevel": "L1",
      "description": "Score/progress needed to win (alias of targetProgress)."
    },
    "difficulty": {
      "type": "integer",
      "default": 1,
      "min": 1,
      "max": 5,
      "patchLevel": "L1",
      "description": "Difficulty scaling for spawn and orb lifetime."
    },
    "artRuntimeMode": {
      "type": "string",
      "default": "prototype",
      "patchLevel": "L1",
      "description": "prototype | production art binding mode."
    },
    "allowQuit": {
      "type": "boolean",
      "default": true,
      "patchLevel": "L1",
      "description": "Allow retreat/quit."
    },
    "allowPause": {
      "type": "boolean",
      "default": true,
      "patchLevel": "L1",
      "description": "Allow pause/resume."
    }
  },
  "patchPolicy": {
    "defaultAllowedLevels": [
      "L0",
      "L1",
      "L2"
    ],
    "requiresReview": [
      "L3",
      "L4"
    ]
  },
  "requiredCoreSystems": [
    "TimingJudge",
    "ProgressBar",
    "ComboTracker",
    "NodeResult",
    "WebAudioSynth"
  ],
  "resultContract": {
    "successReason": "objective_met",
    "telemetry": [
      "bestCombo",
      "perfectHits",
      "goodHits",
      "misses"
    ]
  },
  "testFixture": {
    "type": "e2e",
    "path": null,
    "assertions": [
      "progress increases on valid hit",
      "miss lowers or stalls progress",
      "completion sends NodeResult"
    ]
  },
  "sourceProvenance": [
    "minigame/Path_to_Immortality/node1.html",
    "minigame/Path_to_Immortality/node9.html"
  ],
  "fit": {
    "goodFor": [
      "meditation",
      "breathing",
      "ritual timing",
      "music/rhythm scenes"
    ],
    "poorFor": [
      "complex spatial combat",
      "strategy-heavy nodes"
    ]
  },
  "knownRisks": [
    "latency and animation timing can make strict windows feel unfair",
    "mobile tap feedback must be immediate"
  ],
  "implementationNotes": "Core adapter/modifier wired in minigame_master + GameRunner (2026-07-17).",
  "requiredAssets": {
    "playerClips": [
      "idle"
    ],
    "enemyKinds": [
      "orb"
    ],
    "environments": [
      "bg_default"
    ],
    "audioCues": [
      "bgm_main",
      "sfx_hit",
      "sfx_win",
      "sfx_lose"
    ]
  },
  "performanceBudget": {
    "normalP95Fps": 55,
    "bossP95Fps": 45,
    "maxActiveEnemies": 12
  },
  "maturityImpact": {
    "dimensions": [
      "gameplay",
      "visual",
      "audio",
      "e2e"
    ],
    "notes": "Migrated to Gameplay Card V2 maturity model."
  },
  "testScenarios": [
    {
      "id": "smoke_test",
      "tags": [
        "smoke",
        "runtime"
      ]
    },
    {
      "id": "demo_e2e_enter_retreat_fail_win",
      "tags": [
        "e2e",
        "demo",
        "gate"
      ]
    }
  ],
  "exportPolicy": {
    "productionReady": false,
    "blockReason": "gate_verified only; missing standalone E2E, soak/device FPS, VLM, human signoff, production recipe certification"
  },
  "certificationNotes": {
    "status": "gate_verified",
    "certifiedAt": "2026-07-24",
    "demo": "minigame_master/core/demo/rhythm_timing",
    "e2eScript": "npm run check:rhythm-e2e",
    "readinessScript": "npm run check:rhythm-gate",
    "fixtures": "minigame_master/gameplay/cards/fixtures/rhythm_timing/",
    "evidence": [
      "runtime_e2e_rhythm_timing_latest.json",
      "level_recipe_compile_rhythm_latest.json",
      "rhythm_gate_readiness_latest.json"
    ],
    "nextForProductionReady": [
      "standalone export E2E",
      "visual soak / device FPS",
      "VLM audit",
      "human playtest signoff",
      "production_recipe + exportPolicy.productionReady"
    ]
  }
