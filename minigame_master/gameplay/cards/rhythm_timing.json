{
  "schemaVersion": "2.0",
  "id": "rhythm_timing",
  "title": "Rhythm Timing",
  "category": "timing",
  "status": "runtime_ready",
  "runtime": {
    "engineTargets": [
      "html_canvas",
      "phaser"
    ],
    "adapter": "RhythmTimingAdapter",
    "container": "node_iframe_microgame",
    "template": "rhythm_timing"
  },
  "inputs": [
    "button",
    "pointer"
  ],
  "objectives": [
    "reach_progress",
    "reach_combo"
  ],
  "failure": [
    "retreated",
    "optional_timer_expired"
  ],
  "knobs": {
    "beatIntervalMs": {
      "type": "integer",
      "default": 1500,
      "min": 300,
      "max": 5000,
      "patchLevel": "L1",
      "description": "Timing cycle length."
    },
    "perfectWindowMs": {
      "type": "integer",
      "default": 80,
      "min": 10,
      "max": 500,
      "patchLevel": "L1",
      "description": "Perfect hit timing window."
    },
    "goodWindowMs": {
      "type": "integer",
      "default": 160,
      "min": 10,
      "max": 800,
      "patchLevel": "L1",
      "description": "Good hit timing window."
    },
    "targetProgress": {
      "type": "integer",
      "default": 100,
      "min": 10,
      "max": 1000,
      "patchLevel": "L1",
      "description": "Progress required to complete the node."
    },
    "requiredBestCombo": {
      "type": "integer",
      "default": 18,
      "min": 0,
      "max": 200,
      "patchLevel": "L1",
      "description": "Optional best combo requirement."
    }
  },
  "patchPolicy": {
    "defaultAllowedLevels": [
      "L0",
      "L1",
      "L2"
    ],
    "requiresReview": [
      "L3",
      "L4"
    ]
  },
  "requiredCoreSystems": [
    "TimingJudge",
    "ProgressBar",
    "ComboTracker",
    "NodeResult",
    "WebAudioSynth"
  ],
  "resultContract": {
    "successReason": "objective_met",
    "telemetry": [
      "bestCombo",
      "perfectHits",
      "goodHits",
      "misses"
    ]
  },
  "testFixture": {
    "type": "e2e",
    "path": null,
    "assertions": [
      "progress increases on valid hit",
      "miss lowers or stalls progress",
      "completion sends NodeResult"
    ]
  },
  "sourceProvenance": [
    "minigame/Path_to_Immortality/node1.html",
    "minigame/Path_to_Immortality/node9.html"
  ],
  "fit": {
    "goodFor": [
      "meditation",
      "breathing",
      "ritual timing",
      "music/rhythm scenes"
    ],
    "poorFor": [
      "complex spatial combat",
      "strategy-heavy nodes"
    ]
  },
  "knownRisks": [
    "latency and animation timing can make strict windows feel unfair",
    "mobile tap feedback must be immediate"
  ],
  "implementationNotes": "Core adapter/modifier wired in minigame_master + GameRunner (2026-07-17).",
  "requiredAssets": {
    "playerClips": [
      "idle",
      "walk",
      "attack",
      "hurt",
      "death"
    ],
    "enemyKinds": [
      "mob",
      "elite",
      "boss"
    ],
    "environments": [
      "bg_default"
    ],
    "audioCues": [
      "bgm_main",
      "sfx_attack",
      "sfx_hit",
      "sfx_win",
      "sfx_lose"
    ]
  },
  "performanceBudget": {
    "normalP95Fps": 55,
    "bossP95Fps": 45,
    "maxActiveEnemies": 50
  },
  "maturityImpact": {
    "dimensions": [
