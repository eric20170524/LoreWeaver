{
  "schemaVersion": "2.0",
  "id": "sequence_synthesis",
  "title": "Sequence Synthesis",
  "category": "crafting_puzzle",
  "status": "runtime_ready",
  "runtime": {
    "engineTargets": [
      "html_canvas",
      "phaser"
    ],
    "adapter": "SequenceSynthesisAdapter",
    "container": "node_iframe_microgame",
    "template": "sequence_synthesis"
  },
  "inputs": [
    "pointer",
    "button"
  ],
  "objectives": [
    "complete_recipe_sequence"
  ],
  "failure": [
    "mistakes_exhausted",
    "explosion",
    "retreated"
  ],
  "knobs": {
    "recipeLength": {
      "type": "integer",
      "default": 4,
      "min": 1,
      "max": 20,
      "patchLevel": "L1",
      "description": "Number of ordered ingredients or actions."
    },
    "materialPoolSize": {
      "type": "integer",
      "default": 6,
      "min": 2,
      "max": 30,
      "patchLevel": "L1",
      "description": "Number of possible materials shown."
    },
    "wrongInputProgressPenalty": {
      "type": "number",
      "default": 30,
      "min": 0,
      "max": 100,
      "patchLevel": "L1",
      "description": "Progress lost after a wrong input."
    },
    "explodeOnConsecutiveMistakes": {
      "type": "integer",
      "default": 2,
      "min": 1,
      "max": 10,
      "patchLevel": "L1",
      "description": "Consecutive wrong inputs before hard reset or failure."
    }
  },
  "patchPolicy": {
    "defaultAllowedLevels": [
      "L0",
      "L1",
      "L2"
    ],
    "requiresReview": [
      "L3",
      "L4"
    ]
  },
  "requiredCoreSystems": [
    "RecipeState",
    "InputOrderJudge",
    "ProgressBar",
    "VFX",
    "NodeResult"
  ],
  "resultContract": {
    "successReason": "objective_met",
    "telemetry": [
      "mistakes",
      "recipeLength",
      "elapsedSec"
    ]
  },
  "testFixture": {
    "type": "e2e",
    "path": null,
    "assertions": [
      "correct material advances recipe",
      "wrong material applies penalty",
      "complete recipe sends NodeResult"
    ]
  },
  "sourceProvenance": [
    "minigame/Path_to_Immortality/node11.html"
  ],
  "fit": {
    "goodFor": [
      "alchemy",
      "crafting",
      "ritual order",
      "lock sequence"
    ],
    "poorFor": [
      "reflex-only action nodes"
    ]
  },
  "knownRisks": [
    "strict order can feel like rote clicking without meaningful hints",
    "must expose current required material clearly for accessibility"
  ],
  "implementationNotes": "Core adapter/modifier wired in minigame_master + GameRunner (2026-07-17).",
  "requiredAssets": {
    "playerClips": [
      "idle",
      "walk",
      "attack",
      "hurt",
      "death"
    ],
    "enemyKinds": [
      "mob",
      "elite",
      "boss"
    ],
    "environments": [
      "bg_default"
    ],
    "audioCues": [
      "bgm_main",
      "sfx_attack",
      "sfx_hit",
      "sfx_win",
      "sfx_lose"
    ]
  },
  "performanceBudget": {
    "normalP95Fps": 55,
    "bossP95Fps": 45,
    "maxActiveEnemies": 50
  },
  "maturityImpact": {
    "dimensions": [
      "gameplay",
      "visual",
      "audio",
      "e2e"
    ],
    "notes": "Migrated to Gameplay Card V2 maturity model."
  },
  "testScenarios": [
    {
      "id": "smoke_test",
      "tags": [
        "smoke",
        "runtime"
      ]
    }
  ],
  "exportPolicy": {
    "productionReady": false,
    "blockReason": "Awaiting P1-P7 production readiness certification"
  }
}
