{
  "schemaVersion": "2.0",
  "id": "sequence_synthesis",
  "title": "Sequence Synthesis",
  "category": "crafting_puzzle",
  "status": "production_ready",
  "runtime": {
    "engineTargets": [
      "html_canvas",
      "phaser"
    ],
    "adapter": "SequenceSynthesisAdapter",
    "container": "node_iframe_microgame",
    "template": "sequence_synthesis"
  },
  "inputs": [
    "pointer",
    "button"
  ],
  "objectives": [
    "complete_recipe_sequence"
  ],
  "failure": [
    "mistakes_exhausted",
    "explosion",
    "retreated"
  ],
  "knobs": {
    "recipeLength": {
      "type": "integer",
      "default": 4,
      "min": 1,
      "max": 20,
      "patchLevel": "L1",
      "description": "Number of ordered ingredients or actions."
    },
    "materialPoolSize": {
      "type": "integer",
      "default": 6,
      "min": 2,
      "max": 30,
      "patchLevel": "L1",
      "description": "Number of possible materials shown."
    },
    "wrongInputProgressPenalty": {
      "type": "number",
      "default": 30,
      "min": 0,
      "max": 100,
      "patchLevel": "L1",
      "description": "Progress lost after a wrong input."
    },
    "explodeOnConsecutiveMistakes": {
      "type": "integer",
      "default": 2,
      "min": 1,
      "max": 10,
      "patchLevel": "L1",
      "description": "Consecutive wrong inputs before hard reset or failure."
    },
    "explodeFails": {
      "type": "boolean",
      "default": false,
      "patchLevel": "L1",
      "description": "Consecutive mistakes hard-fail when true."
    },
    "allowQuit": {
      "type": "boolean",
      "default": true,
      "patchLevel": "L1",
      "description": "Allow retreat."
    },
    "allowPause": {
      "type": "boolean",
      "default": true,
      "patchLevel": "L1",
      "description": "Allow pause."
    },
    "artRuntimeMode": {
      "type": "string",
      "default": "prototype",
      "patchLevel": "L1",
      "description": "prototype | production art mode."
    },
    "runSeed": {
      "type": "integer",
      "default": 0,
      "min": 0,
      "max": 999999999,
      "patchLevel": "L1",
      "description": "Optional RNG seed for recipe."
    }
  },
  "patchPolicy": {
    "defaultAllowedLevels": [
      "L0",
      "L1",
      "L2"
    ],
    "requiresReview": [
      "L3",
      "L4"
    ]
  },
  "requiredCoreSystems": [
    "RecipeState",
    "InputOrderJudge",
    "ProgressBar",
    "VFX",
    "NodeResult"
  ],
  "resultContract": {
    "successReason": "objective_met",
    "telemetry": [
      "mistakes",
      "recipeLength",
      "elapsedSec"
    ]
  },
  "testFixture": {
    "type": "e2e",
    "path": null,
    "assertions": [
      "correct material advances recipe",
      "wrong material applies penalty",
      "complete recipe sends NodeResult"
    ]
  },
  "sourceProvenance": [
    "minigame/Path_to_Immortality/node11.html"
  ],
  "fit": {
    "goodFor": [
      "alchemy",
      "crafting",
      "ritual order",
      "lock sequence"
    ],
    "poorFor": [
      "reflex-only action nodes"
    ]
  },
  "knownRisks": [
    "strict order can feel like rote clicking without meaningful hints",
    "must expose current required material clearly for accessibility"
  ],
  "implementationNotes": "Core adapter/modifier wired in minigame_master + GameRunner (2026-07-17).",
  "requiredAssets": {
    "playerClips": [
      "idle"
    ],
    "enemyKinds": [
      "hazard"
    ],
    "environments": [
      "bg_default"
    ],
    "audioCues": [
      "bgm_main",
      "sfx_hit",
      "sfx_win",
      "sfx_lose"
    ]
  },
  "performanceBudget": {
    "normalP95Fps": 55,
    "bossP95Fps": 45,
    "maxActiveEnemies": 8
  },
  "maturityImpact": {
    "dimensions": [
      "gameplay",
      "visual",
      "audio",
      "e2e"
    ],
    "notes": "Migrated to Gameplay Card V2 maturity model."
  },
  "testScenarios": [
    {
      "id": "smoke_test",
      "tags": [
        "smoke",
        "runtime"
      ]
    },
    {
      "id": "demo_e2e_enter_retreat_fail_win",
      "tags": [
        "e2e",
        "demo",
        "gate"
      ]
    }
  ],
  "exportPolicy": {
    "productionReady": true,
    "blockReason": null,
    "conditionalWaivers": [
      "device_class_fps: headless soak avgFps proxy",
      "vlm_visual_overflow: deferred; deterministic visual_audit used",
      "standalone_zip_host_e2e: demo browser gate primary for sequence puzzle card"
    ]
  },
  "certificationNotes": {
    "status": "production_ready",
    "certifiedAt": "2026-07-24",
    "demo": "minigame_master/core/demo/sequence_synthesis",
    "e2eScript": "npm run check:seq-e2e:release",
    "visualSoakScript": "npm run check:seq-visual-soak:release",
    "readinessScript": "npm run check:seq-gate",
    "fixtures": "minigame_master/gameplay/cards/fixtures/sequence_synthesis/",
    "humanSignoff": "docs/reports/step_E3_sequence_synthesis_human_playtest_signoff.md",
    "evidence": [
      "runtime_e2e_sequence_synthesis_latest.json",
      "standalone_browser_report_sequence_synthesis.json",
      "visual_audit_sequence_synthesis_latest.json",
      "performance_report_sequence_synthesis_latest.json",
      "seq_gate_readiness_latest.json",
      "level_recipe_compile_seq_latest.json"
    ],
    "residuals": [
      "true device-class FPS P95",
      "VLM overflow/HUD audit",
      "full standalone export host E2E matrix"
    ]
  }
}
