{
  "schemaVersion": "2.0",
  "id": "node_iframe_microgame",
  "title": "Iframe Node Microgame",
  "category": "container_protocol",
  "status": "runtime_ready",
  "runtime": {
    "engineTargets": [
      "html_canvas"
    ],
    "adapter": "IframeNodeContainer",
    "container": "iframe",
    "template": "node_iframe_microgame"
  },
  "inputs": [
    "pointer",
    "keyboard",
    "message"
  ],
  "objectives": [
    "launch_node",
    "receive_result",
    "close_node"
  ],
  "failure": [
    "node_close_without_result",
    "message_timeout",
    "payload_parse_error"
  ],
  "knobs": {
    "payloadEncoding": {
      "type": "enum",
      "values": [
        "base64_json",
        "plain_json"
      ],
      "default": "base64_json",
      "patchLevel": "L1",
      "description": "How NodePayload is encoded into the iframe URL."
    },
    "messageTypes": {
      "type": "array",
      "default": [
        "NODE_RESULT",
        "NODE_CLOSE",
        "NODE_EXIT"
      ],
      "patchLevel": "L1",
      "description": "Accepted postMessage types from child node pages."
    },
    "fullscreen": {
      "type": "boolean",
      "default": true,
      "patchLevel": "L1",
      "description": "Whether the iframe node overlays the full viewport."
    }
  },
  "patchPolicy": {
    "defaultAllowedLevels": [
      "L0",
      "L1",
      "L2"
    ],
    "requiresReview": [
      "L3",
      "L4"
    ]
  },
  "requiredCoreSystems": [
    "NodePayload",
    "NodeResult",
    "NodeContainer",
    "RewardApplier",
    "TestHooks"
  ],
  "resultContract": {
    "rawRewardFields": [
      "qi",
      "xp",
      "skill",
      "skillUp",
      "relic",
      "unlockAges",
      "flag"
    ],
    "normalizedResult": "NodeResult"
  },
  "testFixture": {
    "type": "e2e",
    "path": null,
    "assertions": [
      "iframe is mounted",
      "payload is readable by child",
      "NODE_RESULT removes iframe",
      "reward is applied once",
      "NODE_CLOSE removes iframe without reward"
    ]
  },
  "sourceProvenance": [
    "minigame/Path_to_Immortality/index.html",
    "minigame/Path_to_Immortality/node1.html",
    "minigame/Path_to_Immortality/battle.html"
  ],
  "fit": {
    "goodFor": [
      "multi-playstyle node collections",
      "legacy HTML minigames",
      "fast prototyping"
    ],
    "poorFor": [
      "tight Phaser scene composition",
      "single-canvas games requiring shared physics"
    ]
  },
  "knownRisks": [
    "postMessage origin is currently wildcard in the source case study",
    "child pages may send partial rewards instead of normalized NodeResult",
    "iframe cleanup must handle close, fail, and result paths"
  ],
  "implementationNotes": "Core adapter/modifier wired in minigame_master + GameRunner (2026-07-17).",
  "requiredAssets": {
    "playerClips": [
      "idle",
      "walk",
      "attack",
      "hurt",
      "death"
    ],
    "enemyKinds": [
      "mob",
      "elite",
      "boss"
    ],
    "environments": [
      "bg_default"
    ],
    "audioCues": [
      "bgm_main",
      "sfx_attack",
      "sfx_hit",
      "sfx_win",
      "sfx_lose"
    ]
  },
  "performanceBudget": {
    "normalP95Fps": 55,
    "bossP95Fps": 45,
    "maxActiveEnemies": 50
  },
  "maturityImpact": {
    "dimensions": [
      "gameplay",
      "visual",
      "audio",
      "e2e"
    ],
    "notes": "Migrated to Gameplay Card V2 maturity model."
  },
  "testScenarios": [
    {
      "id": "smoke_test",
      "tags": [
        "smoke",
        "runtime"
      ]
    }
  ],
  "exportPolicy": {
    "productionReady": false,
    "blockReason": "Awaiting P1-P7 production readiness certification"
  }
}
