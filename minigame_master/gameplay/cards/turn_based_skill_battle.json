{
  "schemaVersion": "2.0",
  "id": "turn_based_skill_battle",
  "title": "Turn-Based Skill Battle",
  "category": "combat",
  "status": "production_ready",
  "runtime": {
    "engineTargets": [
      "html_canvas",
      "phaser"
    ],
    "adapter": "TurnBasedSkillBattleAdapter",
    "container": "node_iframe_microgame",
    "template": "turn_based_skill_battle"
  },
  "inputs": [
    "button",
    "pointer"
  ],
  "objectives": [
    "enemy_hp_zero"
  ],
  "failure": [
    "player_hp_zero",
    "retreated"
  ],
  "knobs": {
    "playerHp": {
      "type": "integer",
      "default": 100,
      "min": 1,
      "max": 999999,
      "patchLevel": "L1",
      "description": "Player hit points at battle start."
    },
    "enemyHp": {
      "type": "integer",
      "default": 1800,
      "min": 1,
      "max": 999999,
      "patchLevel": "L1",
      "description": "Enemy hit points."
    },
    "enemyAtk": {
      "type": "integer",
      "default": 120,
      "min": 0,
      "max": 99999,
      "patchLevel": "L1",
      "description": "Enemy base attack."
    },
    "skillDeck": {
      "type": "array",
      "default": [],
      "patchLevel": "L2",
      "description": "Available player actions with cooldown and effects."
    },
    "rewardTable": {
      "type": "object",
      "default": {},
      "patchLevel": "L1",
      "description": "Rewards granted on victory."
    },
    "artRuntimeMode": {
      "type": "string",
      "default": "prototype",
      "patchLevel": "L1",
      "description": "prototype | production art binding mode."
    },
    "allowQuit": {
      "type": "boolean",
      "default": true,
      "patchLevel": "L1",
      "description": "Allow retreat."
    },
    "allowPause": {
      "type": "boolean",
      "default": true,
      "patchLevel": "L1",
      "description": "Allow pause."
    },
    "playerAtk": {
      "type": "integer",
      "default": 20,
      "min": 0,
      "max": 99999,
      "patchLevel": "L1",
      "description": "Player attack bonus."
    }
  },
  "patchPolicy": {
    "defaultAllowedLevels": [
      "L0",
      "L1",
      "L2"
    ],
    "requiresReview": [
      "L3",
      "L4"
    ]
  },
  "requiredCoreSystems": [
    "NodePayload",
    "NodeResult",
    "ActionBar",
    "CombatLog",
    "Cooldown",
    "RewardApplier"
  ],
  "resultContract": {
    "successReason": "boss_defeated",
    "failureReason": "hp_zero"
  },
  "testFixture": {
    "type": "e2e",
    "path": null,
    "assertions": [
      "battle starts with player and enemy hp",
      "skill click changes hp or cooldown",
      "enemy turn advances",
      "victory sends NodeResult",
      "defeat sends failed NodeResult"
    ]
  },
  "sourceProvenance": [
    "minigame/Path_to_Immortality/battle.html",
    "minigame/Path_to_Immortality/index.html"
  ],
  "fit": {
    "goodFor": [
      "duels",
      "boss tests",
      "dialogue-driven confrontations"
    ],
    "poorFor": [
      "real-time movement-heavy scenes",
      "large enemy swarms"
    ]
  },
  "knownRisks": [
    "combat can become shallow without interesting skill deck constraints",
    "needs strong telemetry for balancing"
  ],
  "implementationNotes": "Core adapter/modifier wired in minigame_master + GameRunner (2026-07-17).",
  "requiredAssets": {
    "playerClips": [
      "idle"
    ],
    "enemyKinds": [
      "boss"
    ],
    "environments": [
      "bg_default"
    ],
    "audioCues": [
      "bgm_main",
      "sfx_hit",
      "sfx_win",
      "sfx_lose"
    ]
  },
  "performanceBudget": {
    "normalP95Fps": 55,
    "bossP95Fps": 45,
    "maxActiveEnemies": 4
