      ]
    },
    {
      "id": "demo_e2e_enter_retreat_fail_win",
      "tags": [
        "e2e",
        "demo",
        "gate"
      ]
    }
  ],
  "exportPolicy": {
    "productionReady": true,
    "blockReason": null,
    "conditionalWaivers": [
