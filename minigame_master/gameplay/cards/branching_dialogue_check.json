{
  "schemaVersion": "2.0",
  "id": "branching_dialogue_check",
  "title": "Branching Dialogue Check",
  "category": "narrative_choice",
  "status": "runtime_ready",
  "runtime": {
    "engineTargets": [
      "phaser",
      "html_canvas"
    ],
    "adapter": "BranchingDialogueCheckAdapter",
    "template": "branching_dialogue_check"
  },
  "inputs": [
    "button",
    "pointer"
  ],
  "objectives": [
    "reach_non_fail_ending"
  ],
  "failure": [
    "fail_ending",
    "retreated"
  ],
  "knobs": {
    "startFavor": {
      "type": "integer",
      "default": 40,
      "min": 0,
      "max": 100,
      "patchLevel": "L1",
      "description": "Starting favor value."
    },
    "dialogueGraph": {
      "type": "array",
      "default": [],
      "patchLevel": "L2",
      "description": "Dialogue nodes with choices and requirements."
    }
  },
  "patchPolicy": {
    "defaultAllowedLevels": [
      "L0",
      "L1",
      "L2"
    ],
    "requiresReview": [
      "L3",
      "L4"
    ]
  },
  "requiredCoreSystems": [
    "ChoiceGraph",
    "ConditionCheck",
    "StoryFlags",
    "NodeResult"
  ],
  "resultContract": {
    "successReason": "objective_met",
    "telemetry": [
      "favor",
      "path",
      "ending",
      "choicesMade"
    ]
  },
  "testFixture": {
    "type": "e2e",
    "path": null,
    "assertions": [
