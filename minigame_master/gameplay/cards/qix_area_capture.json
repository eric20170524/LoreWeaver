    "timeLimitSec": {
      "type": "number",
      "default": 90,
      "patchLevel": "L1",
      "description": "Time limit seconds."
    },
    "gridCols": {
      "type": "integer",
      "default": 24,
      "patchLevel": "L1",
      "description": "Grid columns."
    },
    "gridRows": {
      "type": "integer",
      "default": 16,
      "patchLevel": "L1",
      "description": "Grid rows."
    }
  },
  "patchPolicy": {
    "defaultAllowedLevels": [
      "L0",
      "L1",
      "L2"
    ],
    "requiresReview": [
      "L3",
      "L4"
    ]
  },
  "requiredCoreSystems": [
    "PathTrail",
    "PolygonArea",
    "EnemyCollision",
    "NodeResult"
