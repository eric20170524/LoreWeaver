{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev-restart.sh",
    "dev:raw": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "check:runtime-feature-pack": "node minigame_master/capabilities/verification/check_runtime_feature_pack.mjs",
    "check:docs-collab": "node minigame_master/capabilities/verification/check_docs_collab_evidence.mjs",
    "check:node-smoke": "node minigame_master/capabilities/verification/run_node_smoke.mjs",
    "check:art-binder": "node productize/jobs/check-runtime-art-binder.js",
    "check:survivor-golden-atlas": "node productize/jobs/check-survivor-golden-atlas.js",
    "check:survivor-e2e": "node productize/jobs/run-survivor-e2e.mjs",
    "check:standalone-survivor-e2e": "node productize/jobs/run-standalone-survivor-e2e.mjs",
    "check:survivor-visual-soak": "node productize/jobs/run-survivor-visual-soak.mjs",
    "check:survivor-visual-soak:full": "SOAK_SECONDS=600 node productize/jobs/run-survivor-visual-soak.mjs",
    "check:survivor-c7-readiness": "node productize/jobs/check-survivor-c7-readiness.mjs",
    "check:atlas-integrity": "node productize/jobs/check-atlas-frame-integrity.js",
    "check:survivor-theme-skin": "node productize/jobs/check-survivor-theme-skin.mjs",
    "check:level-recipe": "node productize/jobs/compile-level-recipe.mjs --all",
    "catalog:gameplay": "node productize/jobs/list-gameplay-catalog.mjs",
    "catalog:gameplay:production": "node productize/jobs/list-gameplay-catalog.mjs --production-only",
    "check:catalog-policy": "python3 productize/jobs/check-gameplay-catalog-policy.py",
    "recipe:apply": "node productize/jobs/apply-level-recipe.mjs",
    "recipe:list": "node productize/jobs/apply-level-recipe.mjs --list",
    "check:production-export-gate": "node productize/jobs/check-production-export-gate.mjs",
    "rebuild:survivor-atlas": "python3 productize/jobs/rebuild-survivor-atlas.py",
    "productize:compile": "node productize/compile-workspace.mjs",
    "productize:export": "tsx productize/export-standalone.mjs",
    "productize:card": "node productize/validate-gameplay-card.mjs",
    "productize:asset-job": "node productize/run-asset-job.mjs",
    "productize:patch": "node productize/apply-source-patch.mjs",
    "productize:qa": "node productize/run-full-qa.mjs",
    "productize:accept": "node productize/final-acceptance-package.mjs",
    "productize:runtime-spec-check": "tsx productize/jobs/check-runtime-spec-compiler.ts",
    "productize:runtime-kernel-check": "node productize/jobs/check-runtime-kernel-contract.mjs",
    "productize:runtime-baseline": "node productize/jobs/check-runtime-parity-baseline.js",
    "test:campaign:core-check": "node productize/jobs/check-campaign-core.mjs",
    "test:survivor:channel-check": "node productize/jobs/check-survivor-channel-interaction.mjs",
    "test:survivor:migration-fixtures": "node productize/jobs/check-survivor-migration-fixtures.js"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "phaser": "^4.1.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "playwright": "^1.49.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
