# LLM provider: auto | grok | xai | gemini
# auto = prefer XAI/Grok when XAI_API_KEY is set, else Gemini
LLM_PROVIDER=auto

# xAI Grok (recommended for department prep + GDD + VLM vision)
# Get a key at https://console.x.ai/
XAI_API_KEY=""
# Optional aliases / overrides:
# GROK_API_KEY=""
# XAI_MODEL=grok-4-1-fast-non-reasoning
# XAI_VLM_MODEL=grok-4-1-fast-non-reasoning
# XAI_API_BASE=https://api.x.ai/v1

# Gemini fallback (optional)
# GEMINI_API_KEY=""
# GEMINI_MODEL=gemini-2.0-flash

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# --- Visual audit (VLM) ---
# LOREWEAVER_ENABLE_VLM_AUDIT:
#   unset = auto (on if XAI_API_KEY or ChatGPT.app codex CLI exists)
#   1 = force on
#   0 = deterministic pixel checks only
# LOREWEAVER_ENABLE_CODEX_AUDIT=1 is a legacy alias for force-on.
# LOREWEAVER_ENABLE_VLM_AUDIT=
# LOREWEAVER_VLM_PROVIDER=auto
#   auto | grok | xai | codex | chatgpt
# Codex/ChatGPT CLI path override (default scans ChatGPT.app + PATH):
# CODEX_CLI=/Applications/ChatGPT.app/Contents/Resources/codex

# Note: Antigravity (agy) and Grok Build TUI support interactive coding + image paste,
# but are not used as automated headless VLM backends for /api/audit.

# --- Image Generation (Art Department) ---
# LOREWEAVER_ENABLE_ANTIGRAVITY_IMAGEGEN:
#   1 = Enable Antigravity builtin generate_image tool provider for Art department
#   0 = Disabled (default to standard imagegen manifest / procedural graphics fallback)
# LOREWEAVER_ENABLE_ANTIGRAVITY_IMAGEGEN=1
# IMAGEGEN_PROVIDER=antigravity

